--[[
-- =============================================
-- SCRIPT AUTO HARVEST (BUILD ULANG)
-- =============================================

-- =============================================
-- KONFIGURASI
-- =============================================

ITEM = {
    Seed_ID = 4585,        -- ID bibit yang akan dipanen
    Target_Amount = 190    -- Target jumlah block/seed sebelum drop
}

WORLD = {
    Harvest_World = {"jwttp|baso11"},  -- Daftar world panen
    Drop_World = "homosen|baso99"                    -- World untuk drop
}

DELAY = {
    Harvest = 300,         -- Jeda antar harvest
    Warp = 7000,           -- Jeda setelah warp
    Loop = 2000,           -- Jeda antar siklus utama
    Move = 1000            -- Jeda setelah findPath
}

DROP = {
    Target_Pos = 20,       -- ID foreground tile target untuk drop
    Drop_Index = 2         -- Offset dari tile target (x - offset)
}

-- =============================================
-- STATE (Jangan diubah manual)
-- =============================================

state = {
    warpAttempts = 0,
    Max_Warp_Attempts = 5,
    World_Index = 1,
    paused = false
}
]]
-- =============================================
-- FUNGSI UTILITY
-- =============================================

function send(txt)
    local var = {}
    var[0] = "OnTextOverlay"
    var[1] = txt
    sendVariant(var)
end

function Warp(worldName)
    state.warpAttempts = 0
    local maxAttempts = state.Max_Warp_Attempts or 5

    while state.warpAttempts < maxAttempts do
        send("`2Warping to `#" .. worldName .. " (" .. (state.warpAttempts + 1) .. "/" .. maxAttempts .. ")")
        sendPacket(3, "action|join_request\nname|" .. worldName)
        sleep(DELAY.Warp)

        local currentWorld = getWorld()
        local isCorrect = false
        if currentWorld then
            local targetName = string.upper((worldName:match("([^|]+)") or worldName))
            local currentName = string.upper(currentWorld.name)
            isCorrect = (targetName == currentName)
        end

        if isCorrect then
            send("`2Arrived at `#" .. worldName)
            return true
        else
            state.warpAttempts = state.warpAttempts + 1
            if state.warpAttempts < maxAttempts then
                sleep(5000)
            end
        end
    end

    send("`4Failed to warp to `#" .. worldName)
    state.paused = true
    send("`4Script paused due to warp failure")
    return false
end

function collect(tileX, tileY)
    local collectIDs = {ITEM.Seed_ID, ITEM.Seed_ID - 1}
    for _, id in ipairs(collectIDs) do
        requestCollect(tileX, tileY, id)
        sleep(50)
    end
end


function dropItem(id, count)
    sendPacket(2, "action|drop\n|itemID|" .. id)
    sleep(100)
    sendPacket(2, "action|dialog_return\ndialog_name|drop_item\nitemID|" .. id .. "|\ncount|" .. count)
    sleep(100)
end

function inventory()
    local inv = getInventory()
    if not inv then return 0, 0 end
    
    local block_Amount = 0
    local seed_Amount = 0
    
    for _, item in ipairs(inv) do
        if item.id == ITEM.Seed_ID - 1 then
            block_Amount = item.amount
        end
        if item.id == ITEM.Seed_ID then
            seed_Amount = item.amount
        end
    end
    
    return block_Amount, seed_Amount
end

