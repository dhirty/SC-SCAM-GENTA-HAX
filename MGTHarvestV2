-- =============================================
-- FUNGSI HARVEST
-- =============================================

function Harvest(seedID, delay)
    local harvested = false
    local block_Amount, seed_Amount = inventory()
    
    for _, tile in pairs(getTile()) do
        local extra = getExtraTile(tile.pos.x, tile.pos.y)
        if tile.fg == seedID and extra and extra.ready and block_Amount < ITEM.Target_Amount and seed_Amount < ITEM.Target_Amount then
            findPath(tile.pos.x, tile.pos.y)
            sleep(delay)
            requestTileChange(tile.pos.x, tile.pos.y, 18)
            sleep(delay)
            collect(tile.pos.x, tile.pos.y)
            harvested = true
            block_Amount, seed_Amount = inventory()
        end
    end
    return harvested
end

-- =============================================
-- FUNGSI DROP
-- =============================================

function DropPos()
    local tiles = getTile()
    if not tiles then return false end
    for _, tile in ipairs(tiles) do
        if tile.fg == DROP.Target_Pos then
            local targetX = tile.pos.x - DROP.Drop_Index
            local targetY = tile.pos.y
            findPath(targetX, targetY)
            sleep(DELAY.Move)
            return true
        end
    end
    return false
end

function DropItems()
    local seedID = ITEM.Seed_ID
    
    while true do
        local block_Amount, seed_Amount = inventory()
        
        if block_Amount < ITEM.Target_Amount and seed_Amount < ITEM.Target_Amount then
            break
        end
        
        if not DropPos() then
            send("`4Drop position not found, dropping at current location")
        end
        
        if block_Amount >= ITEM.Target_Amount then
            dropItem(seedID - 1, block_Amount)
        end
        
        if seed_Amount >= ITEM.Target_Amount then
            dropItem(seedID, seed_Amount)
        end
        
        sleep(500)
    end
    return true
end

-- =============================================
-- FUNGSI NEXT WORLD
-- =============================================

function NextWorld()
    state.World_Index = state.World_Index + 1
    if state.World_Index > #WORLD.Harvest_World then
        state.World_Index = 1
    end
    local nextWorld = WORLD.Harvest_World[state.World_Index]
    return Warp(nextWorld)
end

-- =============================================
-- FUNGSI MAIN
-- =============================================

function Main()
    if state.paused then return end
    
    local block_Amount, seed_Amount = inventory()
    
    if block_Amount >= ITEM.Target_Amount or seed_Amount >= ITEM.Target_Amount then
        -- Drop phase
        if not Warp(WORLD.Drop_World) then
            return
        end
        if DropPos() then
            DropItems()
            send("`2Drop completed")
        else
            send("`4Drop position not found, dropping at current location")
            DropItems()
        end
    else
        -- Harvest phase
        local currentWorld = WORLD.Harvest_World[state.World_Index]
        if not Warp(currentWorld) then
            return
        end
        local harvested = Harvest(ITEM.Seed_ID, DELAY.Harvest)
        if not harvested then
            send("`9No ready plants, moving to next world")
            NextWorld()
        end
    end
end

-- =============================================
-- HOOK ERROR DROP
-- =============================================

AddHook("onvarlist", "DropError", function(vlist, netID)
    if vlist and vlist[0] == "OnTextOverlay" and vlist[1] then
        if string.find(vlist[1], "You can't") then
            DROP.Drop_Index = DROP.Drop_Index + 1
            send("`4Offset increased to: " .. DROP.Drop_Index)
        end
    elseif vlist and vlist[0] == "OnConsoleMessage" and vlist[1] then
        if string.find(vlist[1], "World Locked") and state.paused then
            state.paused = false
            send("`4Script continue.")
        end
    elseif vlist and vlist[0] == "OnDialogRequest" and vlist[1] then
        if string.find(vlist[1], "add_textbox|How many to drop?") then
            send("`wDrop Items.")
            return true
        end
    end
    return false
end)

-- =============================================
-- LOOP UTAMA
-- =============================================

while true do
    if not state.paused then
        local success, err = pcall(Main)
        if not success then
            send("`4Error: " .. tostring(err))
            logToConsole("Error: " .. tostring(err))
            state.paused = true
            send("`4Script paused due to error")
        end
    else
        send("`4Script paused. Witing to continue")
        sleep(5000)
    end
    sleep(DELAY.Loop)
end












